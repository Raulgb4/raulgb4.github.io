---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import { LANGS, type Lang, t } from "../../i18n";

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;

const pageSeo = {
  en: {
    title: "Contact | Raúl García Balongo",
    description:
      "Get in touch to discuss opportunities, collaborations, or professional projects related to data and software engineering.",
  },
  es: {
    title: "Contacto | Raúl García Balongo",
    description:
      "Ponte en contacto para hablar sobre oportunidades, colaboraciones o proyectos profesionales relacionados con datos y desarrollo de software.",
  },
};

const email = "raulgarciabalongoes@gmail.com";
const linkedinUrl = "https://www.linkedin.com/in/ra%C3%BAl-garc%C3%ADa-balongo-865948350/";
const githubUrl = "https://github.com/Raulgb4";
const cvUrl =
  lang === "es"
    ? "/assets/genericCV/Mi_CV_en_español.pdf"
    : "/assets/genericCV/Mi_CV_en_inglés.pdf";
const locationText = "Urb. La Cornisa, Avd. Europa, 11204, Algeciras, Cádiz, Spain";
---

<!--
  Contact.astro
  -------------
  Internationalized contact page that provides clear and accessible ways
  to get in touch. It defines language-specific SEO metadata, uses shared
  layout and reveal animations, and presents contact details, social links,
  and location information in a structured, responsive layout.
-->
<Layout lang={lang} pageSeo={pageSeo}>
  <section class="max-w-5xl mx-auto px-4 py-16 space-y-10">
    <!-- Title -->
    <Reveal as="header" delay={0} class="relative mb-8 max-w-3xl mx-auto text-center">
      <!-- Decorative tech dot -->
      <div
        class="absolute -top-8 left-1/2 -translate-x-1/2
      h-4 w-4 rounded-full
      bg-emerald-400/80
      shadow-[0_0_25px_rgba(52,211,153,0.7)]"
        aria-hidden="true"
      >
      </div>

      <h1
        class="text-4xl md:text-5xl font-bold tracking-tight
      bg-linear-to-r from-emerald-400 via-teal-400 to-green-500
      bg-clip-text text-transparent"
      >
        {t(lang, "contact.title")}
      </h1>

      <p class="mt-6 text-lg md:text-xl leading-relaxed
      text-gray-600 dark:text-gray-300">
        {t(lang, "contact.subtitle")}
      </p>
    </Reveal>

    <section class="flex flex-col items-center gap-12">
      <!-- Contact Info -->
      <Reveal delay={140} class="flex justify-center w-full">
        <div
          class="w-full max-w-4xl
        rounded-2xl border border-gray-200 dark:border-white/10
        bg-white/60 dark:bg-white/5 backdrop-blur p-7"
        >
          <div>
            <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">
              {t(lang, "contact.infoTitle")}
            </h2>
          </div>

          <p class="mt-3 text-base text-gray-600 dark:text-gray-300">
            {t(lang, "contact.responseTime")}
          </p>

          <!-- Primary actions -->
          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
            <a
              href={`mailto:${email}`}
              aria-label={t(lang, "contact.sendEmail")}
              class="inline-flex w-full items-center justify-center rounded-full
             bg-emerald-600 px-6 py-3 text-sm font-semibold text-white
             shadow-md shadow-emerald-600/30 transition-all duration-200
             hover:bg-emerald-700 hover:shadow-emerald-600/40
             focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2
             dark:focus:ring-offset-slate-900 sm:w-auto"
            >
              {t(lang, "contact.sendEmail")}
            </a>

            <a
              href={linkedinUrl}
              target="_blank"
              rel="noreferrer"
              aria-label={t(lang, "contact.linkedin")}
              class="inline-flex w-full items-center justify-center rounded-full
             border border-emerald-500/25 bg-emerald-500/10 px-6 py-3
             text-sm font-semibold text-emerald-700 transition-colors
             hover:bg-emerald-500/15 hover:text-emerald-800
             focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2
             dark:text-emerald-300 dark:hover:text-emerald-200 dark:focus:ring-offset-slate-900 sm:w-auto"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="mr-2 h-4 w-4"
                aria-hidden="true"
              >
                <path
                  d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.68H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.1 20.45H3.54V9H7.1v11.45ZM22.23 0H1.76C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.76 24h20.47c.97 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0Z"
                ></path>
              </svg>
              {t(lang, "contact.linkedin")}
            </a>

            <a
              href={cvUrl}
              download
              aria-label={t(lang, "contact.downloadCv")}
              class="inline-flex w-full items-center justify-center rounded-full
             border border-gray-200 bg-white/70 px-6 py-3 text-sm font-semibold
             text-gray-700 transition-colors hover:border-emerald-500/40
             hover:text-emerald-700 focus:outline-none focus:ring-2
             focus:ring-emerald-400 focus:ring-offset-2
             dark:border-white/10 dark:bg-white/5 dark:text-gray-300
             dark:hover:text-emerald-300 dark:focus:ring-offset-slate-900 sm:w-auto"
            >
              {t(lang, "contact.downloadCv")}
            </a>
          </div>

          <!-- Supporting details -->
          <div class="mt-8 space-y-6 border-t border-gray-200/70 pt-6 dark:border-white/10">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full
                bg-emerald-500/10 text-emerald-500"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-6 w-6 block"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5A2.25 2.25 0 0 1 19.5 19.5h-15A2.25 2.25 0 0 1 2.25 17.25V6.75A2.25 2.25 0 0 1 4.5 4.5h15a2.25 2.25 0 0 1 2.25 2.25Z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 7.5 12 13.5 2.25 7.5"></path>
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <div class="font-semibold text-gray-900 dark:text-white">
                  {t(lang, "common.email")}
                </div>
                <div class="mt-1 flex flex-col items-start gap-2 sm:flex-row sm:items-center">
                  <a
                    href={`mailto:${email}`}
                    class="break-all text-gray-600 transition-colors hover:text-emerald-600
                   focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2
                   dark:text-gray-300 dark:hover:text-emerald-400 dark:focus:ring-offset-slate-900"
                  >
                    {email}
                  </a>
                  <button
                    type="button"
                    data-copy-email
                    data-email={email}
                    data-copy-label={t(lang, "contact.copyEmail")}
                    data-copied-label={t(lang, "contact.emailCopied")}
                    class="inline-flex w-fit items-center justify-center rounded-full
                   border border-emerald-500/25 bg-emerald-500/10 px-3 py-1.5
                   text-xs font-semibold text-emerald-700 transition-colors
                   hover:bg-emerald-500/15 hover:text-emerald-800
                   focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2
                   dark:text-emerald-300 dark:hover:text-emerald-200 dark:focus:ring-offset-slate-900"
                  >
                    {t(lang, "contact.copyEmail")}
                  </button>
                </div>
              </div>
            </div>

            <!-- GitHub -->
            <div class="flex items-start gap-4">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full
                bg-emerald-500/10 text-emerald-500"
              >
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/github/github-original.svg"
                  alt=""
                  class="h-6 w-6 dark:invert"
                  aria-hidden="true"
                />
              </div>

              <div class="min-w-0">
                <div class="font-semibold text-gray-900 dark:text-white">GitHub</div>
                <a
                  href={githubUrl}
                  target="_blank"
                  rel="noreferrer"
                  aria-label="GitHub"
                  class="mt-1 inline-flex text-gray-600 transition-colors
                  hover:text-emerald-600 focus:outline-none focus:ring-2
                  focus:ring-emerald-400 focus:ring-offset-2
                  dark:text-gray-300 dark:hover:text-emerald-400
                  dark:focus:ring-offset-slate-900"
                >
                  github.com/Raulgb4
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full
                bg-emerald-500/10 text-emerald-500"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="h-6 w-6 block"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                  ></path>
                </svg>
              </div>

              <div class="min-w-0 w-full">
                <div class="font-semibold text-gray-900 dark:text-white">
                  {t(lang, "common.location")}
                </div>

                <p class="mt-1 text-gray-600 dark:text-gray-300">
                  {locationText}
                </p>

                <details class="mt-4 group">
                  <summary
                    class="cursor-pointer text-sm font-semibold text-emerald-700
                    transition-colors hover:text-emerald-800 focus:outline-none
                    focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2
                    dark:text-emerald-300 dark:hover:text-emerald-200
                    dark:focus:ring-offset-slate-900"
                  >
                    {t(lang, "contact.mapToggle")}
                  </summary>

                  <div
                    class="mt-4 overflow-hidden rounded-xl
                  border border-gray-200 dark:border-white/10
                  shadow-sm transition
                  hover:shadow-lg hover:shadow-emerald-500/10"
                  >
                    <iframe
                      title="Map location"
                      src="https://www.google.com/maps?q=36.1325,-5.4475&z=7&output=embed"
                      class="h-40 w-full"
                      loading="lazy"></iframe>
                  </div>
                </details>
              </div>
            </div>
          </div>
        </div>
      </Reveal>
    </section>
  </section>

  <script>
    function initCopyEmail() {
      const button = document.querySelector("[data-copy-email]");

      if (!(button instanceof HTMLElement)) return;
      if (button.dataset.bound === "true") return;

      button.dataset.bound = "true";

      const defaultLabel = button.dataset.copyLabel || button.textContent || "Copy email";

      const copiedLabel = button.dataset.copiedLabel || "Email copied";

      const email = button.dataset.email;

      button.addEventListener("click", async () => {
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);

          button.textContent = copiedLabel;

          window.setTimeout(() => {
            button.textContent = defaultLabel;
          }, 1800);
        } catch {
          button.textContent = defaultLabel;
        }
      });
    }

    document.addEventListener("DOMContentLoaded", initCopyEmail);
    document.addEventListener("astro:page-load", initCopyEmail);
  </script>
</Layout>
